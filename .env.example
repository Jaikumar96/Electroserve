# ElectroServe deployment environment template

# Backend profile
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Managed MySQL connection for production
SPRING_DATASOURCE_URL=jdbc:mysql://<HOST>:3306/electroserve?createDatabaseIfNotExist=true&useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=<DB_USER>
SPRING_DATASOURCE_PASSWORD=<DB_PASSWORD>

# Security
JWT_SECRET=<LONG_RANDOM_SECRET_32_PLUS_CHARS>

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://<your-vercel-app>.vercel.app

# Frontend
FRONTEND_API_URL=https://<your-render-backend>.onrender.com/api
