# ElectroServe Render backend environment template (Vercel Neon Postgres)
# Copy this whole file content into Render -> Environment -> Add from .env

SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Neon values from Vercel Storage page
SPRING_DATASOURCE_URL=jdbc:postgresql://<PGHOST_UNPOOLED>:5432/<PGDATABASE>?sslmode=require
SPRING_DATASOURCE_USERNAME=<PGUSER>
SPRING_DATASOURCE_PASSWORD=<PGPASSWORD>
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=2
SPRING_SQL_INIT_MODE=never

# Put a long random secret (32+ chars)
JWT_SECRET=<LONG_RANDOM_SECRET_32_PLUS_CHARS>

# Temporary while frontend is not deployed; replace with your Vercel URL later
CORS_ALLOWED_ORIGINS=https://dummy.vercel.app
